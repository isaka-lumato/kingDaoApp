# Supabase — use the new publishable/secret key system (D-020). Do NOT use legacy anon/service_role.
# Get these from: Supabase Dashboard → your project → Settings → API Keys

# Public — safe to ship to the browser. Prefix with NEXT_PUBLIC_ exposes it to client bundles.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# Server-only — NEVER prefix with NEXT_PUBLIC_, NEVER paste in chat, NEVER commit a real value.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxx

# Resend (email alerts, T-053). Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxx

# Shared secret between the scheduled-job invoker and the alerts edge function (D-020).
# Generate any long random string (e.g. `openssl rand -hex 32`).
ALERTS_CRON_SECRET=replace-with-a-long-random-string
